---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Forums — Naturally San Diego">

  <PageHero
    eyebrow="Programs"
    title="Forums"
    subtitle="Coming soon."
    bgColor="#00B2AD"
  />

  <section class="py-16 px-6 lg:px-10">
    <div class="max-w-2xl mx-auto text-center">
      <div class="bg-[#f9f9f8] rounded-2xl px-8 py-12">
        <p
          class="text-lg font-semibold text-[#111] mb-3"
          style="font-family: 'Poppins', sans-serif;"
        >
          We're working on it.
        </p>
        <p class="text-sm text-[#111]/60 mb-8" style="font-family: 'Lato', sans-serif;">
          Forums are in development. In the meantime, the Slack community is where most of those conversations already happen.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/resources/slack"
            class="bg-[#00AD5A] hover:bg-[#006A45] text-white font-bold text-sm px-6 py-3 rounded-full transition-colors"
            style="font-family: 'Poppins', sans-serif;"
          >
            Join Our Slack
          </a>
          <a
            href="/programs/event-calendar"
            class="border border-gray-200 hover:border-gray-400 text-gray-700 font-bold text-sm px-6 py-3 rounded-full transition-colors"
            style="font-family: 'Poppins', sans-serif;"
          >
            See Upcoming Events
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
