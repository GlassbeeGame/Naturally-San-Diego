---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Privacy Policy — Naturally San Diego">

  <PageHero title="Privacy Policy" />

  <section class="py-16 px-6 lg:px-10">
    <div class="max-w-2xl mx-auto">
      <!-- 🔴 NEEDS CLIENT INPUT: legal content -->
      <div class="bg-[#f9f9f8] rounded-2xl px-8 py-10">
        <p class="text-base text-[#111]/70 leading-relaxed mb-4" style="font-family: 'Lato', sans-serif;">
          This page is being updated.
        </p>
        <p class="text-sm text-[#111]/50" style="font-family: 'Lato', sans-serif;">
          For questions about our privacy practices, please contact <a href="mailto:info@naturallysandiego.org" class="text-[#00AD5A] hover:underline">info@naturallysandiego.org</a>.
        </p>
      </div>
    </div>
  </section>

</Layout>
