---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Press — Naturally San Diego">

  <PageHero
    eyebrow="About"
    title="In the Press"
  />

  <section class="py-16 px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="bg-[#f9f9f8] rounded-2xl px-8 py-12 text-center max-w-lg mx-auto">
        <p
          class="text-lg font-semibold text-[#111] mb-3"
          style="font-family: 'Poppins', sans-serif;"
        >
          Press coverage coming soon.
        </p>
        <p class="text-sm text-[#111]/60 mb-6" style="font-family: 'Lato', sans-serif;">
          For media inquiries, please reach out directly.
        </p>
        <a
          href="mailto:info@naturallysandiego.org"
          class="inline-block bg-[#F26447] hover:bg-orange-600 text-white font-bold text-sm px-6 py-3 rounded-full transition-colors"
          style="font-family: 'Poppins', sans-serif;"
        >
          info@naturallysandiego.org
        </a>
      </div>
    </div>
  </section>

</Layout>
