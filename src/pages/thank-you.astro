---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Thanks — Naturally San Diego">

  <PageHero
    title="Thanks for reaching out!"
    subtitle="We'll be in touch within 1–2 business days."
    bgColor="#00AD5A"
  />

  <section class="py-16 px-6 lg:px-10 text-center">
    <a
      href="/"
      class="inline-block bg-[#F26447] hover:bg-orange-600 text-white font-bold text-sm px-7 py-3.5 rounded-full transition-colors"
      style="font-family: 'Poppins', sans-serif;"
    >
      ← Back to Home
    </a>
  </section>

</Layout>
