---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import SponsorStrip from '../../components/SponsorStrip.astro';
import FormspreeForm from '../../components/FormspreeForm.astro';

const inquiryFields = [
  { name: 'name', label: 'Your Name', type: 'text' as const, required: true, placeholder: 'Jane Smith' },
  { name: 'company', label: 'Company', type: 'text' as const, required: true, placeholder: 'Your Company Name' },
  { name: 'email', label: 'Email Address', type: 'email' as const, required: true, placeholder: 'jane@company.com' },
  { name: 'phone', label: 'Phone (optional)', type: 'tel' as const, placeholder: '(619) 555-0100' },
  {
    name: 'tier',
    label: 'Tier of Interest',
    type: 'select' as const,
    required: true,
    options: ['Platinum', 'Gold', 'Silver', 'Bronze', 'Emerging Brands', 'Naturally Network Partner', 'Not sure yet'],
  },
  { name: 'message', label: 'Message', type: 'textarea' as const, placeholder: 'Tell us about your goals and any questions you have...' },
];
---

<Layout title="Sponsorship — Naturally San Diego">

  <PageHero
    eyebrow="Community"
    title="Get in the room and stay there."
    subtitle="Sponsorship that puts your brand where San Diego's natural products decisions get made."
    bgColor="#00AD5A"
  />

  <!-- Why Sponsor -->
  <section class="py-16 px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-14">
        {[
          {
            title: 'Brand Exposure',
            body: 'Your logo, name, and message in front of San Diego\'s natural products community. Every event, every email, across the whole ecosystem.',
          },
          {
            title: 'Community Access',
            body: 'Get in the room with the brands, founders, and professionals who are building the next generation of natural products companies.',
          },
          {
            title: 'Year-Round Presence',
            body: 'Sponsorship isn\'t a one-day thing. Your name is with us at Naturally Rising, networking nights, facility tours, and everything in between.',
          },
        ].map(item => (
          <div class="bg-[#f9f9f8] rounded-2xl px-7 py-8">
            <h3
              class="text-lg font-black text-[#111] mb-3"
              style="font-family: 'Poppins', sans-serif;"
            >
              {item.title}
            </h3>
            <p class="text-sm text-[#111]/60 leading-relaxed" style="font-family: 'Lato', sans-serif;">
              {item.body}
            </p>
          </div>
        ))}
      </div>

      <p class="text-lg text-[#111]/70 leading-relaxed max-w-3xl" style="font-family: 'Lato', sans-serif;">
        Naturally San Diego sponsors aren't just cutting a check. They're in the room. They're on the stage. They're the first phone call a new founder makes when they need a co-packer, a banker, or a lawyer who actually gets CPG.
      </p>
    </div>
  </section>

  <!-- Current sponsors -->
  <SponsorStrip />

  <!-- Tiers -->
  <section class="py-16 px-6 lg:px-10 bg-[#f9f9f8]">
    <div class="max-w-7xl mx-auto">
      <h2
        class="text-xs font-bold uppercase tracking-widest text-[#00AD5A] mb-8"
        style="font-family: 'Poppins', sans-serif;"
      >
        Sponsorship Tiers
      </h2>
      <!-- 🔴 NEEDS CLIENT INPUT: sponsorship deck data — tier benefits, pricing -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {['Platinum', 'Gold', 'Silver', 'Bronze', 'Emerging Brands', 'Naturally Network Partners'].map((tier, i) => (
          <div class={`bg-white rounded-2xl border border-gray-100 px-7 py-8 ${i === 0 ? 'border-[#C3DB66] border-2' : ''}`}>
            <p
              class="text-xs font-bold uppercase tracking-widest text-[#00AD5A] mb-2"
              style="font-family: 'Poppins', sans-serif;"
            >
              {tier}
            </p>
            <p class="text-sm text-[#111]/50 italic" style="font-family: 'Lato', sans-serif;">
              Benefits and pricing in the sponsorship deck. Contact Renee for details.
            </p>
          </div>
        ))}
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <!-- 🔴 NEEDS CLIENT INPUT: sponsorship deck PDF URL -->
        <a
          href="#"
          class="inline-block bg-[#F26447] hover:bg-orange-600 text-white font-bold text-sm px-7 py-3.5 rounded-full transition-colors"
          style="font-family: 'Poppins', sans-serif;"
        >
          Download Sponsorship Deck
        </a>
        <a
          href="mailto:renee@naturallysandiego.org"
          class="inline-block border border-gray-200 hover:border-gray-400 text-gray-700 font-bold text-sm px-7 py-3.5 rounded-full transition-colors"
          style="font-family: 'Poppins', sans-serif;"
        >
          Email Renee Directly
        </a>
      </div>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section class="py-16 lg:py-20 px-6 lg:px-10">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-start">

      <!-- ── Left: Context card ───────────────────────────── -->
      <div class="bg-[#111] rounded-3xl p-8 lg:p-10 flex flex-col gap-8 relative overflow-hidden">

        <div
          class="absolute inset-0 opacity-[0.06]"
          style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 20px 20px;"
          aria-hidden="true"
        ></div>

        <!-- Logo lockup -->
        <div class="relative flex items-center gap-3">
          <img src="/NN_Icon.png" alt="" aria-hidden="true" class="h-10 w-10 rounded-full" />
          <span style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 1rem; color: #fff; line-height: 1.2;">
            Naturally<br /><span style="color: rgba(255,255,255,0.55); font-weight: 600;">San Diego</span>
          </span>
        </div>

        <div class="relative h-px bg-white/10"></div>

        <div class="relative">
          <p class="text-xs font-bold uppercase tracking-widest text-[#C3DB66] mb-3" style="font-family: 'Poppins', sans-serif;">
            What You Get
          </p>
          <ul class="flex flex-col gap-2.5">
            {[
              'Logo and name at every NSD event',
              'Placement in member emails and newsletters',
              'Featured on the website sponsor page',
              'Access to the full NSD community year-round',
              'Recognition across social channels',
            ].map(item => (
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-[#C3DB66] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-white/70 leading-snug" style="font-family: 'Lato', sans-serif;">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="relative h-px bg-white/10"></div>

        <div class="relative">
          <p class="text-xs font-bold uppercase tracking-widest text-[#C3DB66] mb-2" style="font-family: 'Poppins', sans-serif;">
            Prefer to Talk Directly?
          </p>
          <p class="text-sm text-white/55 leading-relaxed mb-3" style="font-family: 'Lato', sans-serif;">
            Reach Renee Solares, Executive Director, at:
          </p>
          <a
            href="mailto:renee@naturallysandiego.org"
            class="text-sm font-semibold text-white hover:text-[#C3DB66] transition-colors"
            style="font-family: 'Lato', sans-serif;"
          >
            renee@naturallysandiego.org
          </a>
        </div>

      </div>

      <!-- ── Right: Form card ─────────────────────────────── -->
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-8 lg:p-10">
        <div class="mb-8">
          <p class="text-xs font-bold uppercase tracking-widest text-[#00AD5A] mb-2" style="font-family: 'Poppins', sans-serif;">
            Sponsorship Inquiry
          </p>
          <h2 class="text-2xl font-black text-[#111]" style="font-family: 'Poppins', sans-serif; letter-spacing: -0.02em;">
            Let's find the right fit.
          </h2>
          <p class="text-sm text-[#111]/55 mt-2" style="font-family: 'Lato', sans-serif;">
            Renee will be in touch within 1–2 business days.
          </p>
        </div>
        <!-- TODO: add Formspree endpoint — create account at formspree.io (Sponsor Inquiry → renee@naturallysandiego.org) -->
        <FormspreeForm
          action=""
          fields={inquiryFields}
          submitLabel="Send Inquiry"
        />
      </div>

    </div>
  </section>

</Layout>
