---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="CPG Academy — Naturally San Diego">

  <PageHero
    eyebrow="Resources"
    title="CPG Academy"
    subtitle="Education for natural products founders."
    bgColor="#00B2AD"
  />

  <section class="py-16 px-6 lg:px-10">
    <div class="max-w-2xl mx-auto text-center">
      <!-- 🔴 NEEDS CLIENT INPUT: CPG Academy program description — not documented on current site -->
      <div class="bg-[#f9f9f8] rounded-2xl px-8 py-12">
        <p
          class="text-lg font-semibold text-[#111] mb-3"
          style="font-family: 'Poppins', sans-serif;"
        >
          In development.
        </p>
        <p class="text-sm text-[#111]/60 mb-8" style="font-family: 'Lato', sans-serif;">
          CPG Academy programming is coming. Become a member to be the first to know when it launches.
        </p>
        <a
          href="/community/membership"
          class="inline-block bg-[#F26447] hover:bg-orange-600 text-white font-bold text-sm px-6 py-3 rounded-full transition-colors"
          style="font-family: 'Poppins', sans-serif;"
        >
          Become a Member
        </a>
      </div>
    </div>
  </section>

</Layout>
