---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Member Wins — Naturally San Diego">

  <PageHero
    eyebrow="Resources"
    title="Member Wins"
    subtitle="Celebrating what this community is building."
    bgColor="#00B2AD"
  />

  <section class="py-16 px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
      <p class="text-base text-[#111]/70 leading-relaxed max-w-xl mb-10" style="font-family: 'Lato', sans-serif;">
        Big wins, small wins, milestone wins. They all count. Member Wins is where the Naturally San Diego community shares what's happening in their world.
      </p>

      <!-- Placeholder grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        {Array.from({ length: 6 }).map((_, i) => (
          <div class="bg-[#f9f9f8] rounded-2xl px-6 py-8 flex flex-col justify-between min-h-[160px]">
            <p class="text-sm text-[#111]/30 italic" style="font-family: 'Lato', sans-serif;">Member wins coming soon...</p>
          </div>
        ))}
      </div>

      <div class="border-t border-gray-100 pt-8">
        <p class="text-base font-semibold text-[#111] mb-2" style="font-family: 'Poppins', sans-serif;">
          Have a win to share?
        </p>
        <p class="text-sm text-[#111]/60 mb-4" style="font-family: 'Lato', sans-serif;">
          We love to hear what our members are celebrating. Submit your news and we'll share it with the community.
        </p>
        <a
          href="/resources/submit"
          class="inline-block bg-[#F26447] hover:bg-orange-600 text-white font-bold text-sm px-6 py-3 rounded-full transition-colors"
          style="font-family: 'Poppins', sans-serif;"
        >
          Submit Your Win →
        </a>
      </div>
    </div>
  </section>

</Layout>
