---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Member Portal — Naturally San Diego">

  <div class="min-h-screen grid grid-cols-1 lg:grid-cols-2">

    <!-- ── Left: Brand panel ──────────────────────────────── -->
    <div class="relative bg-[#111] flex flex-col justify-between p-10 lg:p-16 overflow-hidden min-h-[40vh] lg:min-h-screen">


      <!-- Top: Logo -->
      <a href="/" class="relative flex items-center gap-3 w-fit">
        <img src="/NN_Icon.png" alt="" aria-hidden="true" class="h-10 w-10 rounded-full" />
        <span style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 1rem; color: #fff; line-height: 1.2;">
          Naturally<br /><span style="color: rgba(255,255,255,0.55); font-weight: 600;">San Diego</span>
        </span>
      </a>

      <!-- Middle: Headline -->
      <div class="relative">
        <p class="text-xs font-bold uppercase tracking-widest text-[#C3DB66] mb-4" style="font-family: 'Poppins', sans-serif;">Member Portal</p>
        <h1 class="text-4xl lg:text-5xl font-black text-white leading-tight mb-5" style="font-family: 'Poppins', sans-serif; letter-spacing: -0.03em;">
          Your community<br />is waiting.
        </h1>
        <p class="text-base text-white/60 leading-relaxed max-w-sm" style="font-family: 'Lato', sans-serif;">
          Events, the member directory, Slack, and everything else. All through your GlueUp account.
        </p>
      </div>

      <!-- Bottom: Not a member -->
      <div class="relative">
        <p class="text-xs text-white/40 mb-1.5" style="font-family: 'Lato', sans-serif;">Not a member yet?</p>
        <a
          href="/community/membership"
          class="text-sm font-bold text-[#C3DB66] hover:text-white transition-colors"
          style="font-family: 'Poppins', sans-serif;"
        >
          Learn about membership →
        </a>
      </div>

    </div>

    <!-- ── Right: Sign-in panel ───────────────────────────── -->
    <div class="bg-white flex flex-col justify-center items-center px-8 py-16 lg:px-16">
      <div class="w-full max-w-sm">

        <!-- Icon -->
        <div class="w-14 h-14 rounded-2xl bg-[#006A45]/8 flex items-center justify-center mb-8">
          <svg class="w-7 h-7 text-[#006A45]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>

        <!-- Heading -->
        <p class="text-xs font-bold uppercase tracking-widest text-[#00AD5A] mb-2" style="font-family: 'Poppins', sans-serif;">Welcome back</p>
        <h2 class="text-3xl font-black text-[#111] mb-2" style="font-family: 'Poppins', sans-serif; letter-spacing: -0.02em;">Sign in to<br />your account</h2>
        <p class="text-sm text-[#111]/50 mb-10 leading-relaxed" style="font-family: 'Lato', sans-serif;">
          You'll be taken to GlueUp, our secure membership platform.
        </p>

        <!-- CTA -->
        <a
          href="https://naturallysandiego.glueup.com/login"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full bg-[#F26447] hover:bg-orange-600 text-white font-bold text-sm px-8 py-4 rounded-full transition-colors"
          style="font-family: 'Poppins', sans-serif;"
        >
          Sign In via GlueUp
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <!-- Divider -->
        <div class="flex items-center gap-3 my-6">
          <div class="flex-1 h-px bg-gray-100"></div>
          <span class="text-xs text-[#111]/30" style="font-family: 'Lato', sans-serif;">need help?</span>
          <div class="flex-1 h-px bg-gray-100"></div>
        </div>

        <!-- Support -->
        <p class="text-xs text-center text-[#111]/40 leading-relaxed" style="font-family: 'Lato', sans-serif;">
          Email us at <a href="mailto:info@naturallysandiego.org" class="text-[#00AD5A] hover:underline font-semibold">info@naturallysandiego.org</a>
        </p>

      </div>
    </div>

  </div>

</Layout>
