---
const navItems = [
  {
    label: 'About',
    href: '/about',
    color: '#006A45',
    children: [
      { label: 'Our Story', href: '/about/our-story' },
      { label: 'Leadership', href: '/about/leadership' },
      { label: 'Our Sponsors', href: '/about/sponsors' },
      { label: 'Press', href: '/about/press' },
      { label: 'Contact Us', href: '/about/contact' },
    ],
  },
  {
    label: 'Programs',
    href: '/programs',
    color: '#00B2AD',
    children: [
      { label: 'Naturally Rising', href: '/programs/naturally-rising' },
      { label: 'Monthly Events', href: '/programs/monthly-events' },
      { label: 'Event Calendar', href: '/programs/event-calendar' },
      { label: 'Forums', href: '/programs/forums' },
    ],
  },
  {
    label: 'Community',
    href: '/community',
    color: '#00AD5A',
    children: [
      { label: 'Membership', href: '/community/membership' },
      { label: 'Sponsorship', href: '/community/sponsorship' },
    ],
  },
  {
    label: 'Resources',
    href: '/resources',
    color: '#00B2AD',
    children: [
      { label: 'Job Board', href: '/resources/job-board' },
      { label: 'CPG Academy', href: '/resources/cpg-academy' },
      { label: 'Member Wins', href: '/resources/member-wins' },
      { label: 'Slack Community', href: '/resources/slack' },
      { label: 'Submit News', href: '/resources/submit' },
    ],
  },
];
---

<header class="bg-white border-b border-gray-100/80 sticky top-0 z-50" style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="flex-shrink-0 flex items-center gap-2.5">
      <img
        src="/NN_Icon.png"
        alt=""
        aria-hidden="true"
        class="h-9 w-9 rounded-full"
      />
      <span style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 0.9rem; line-height: 1.1; letter-spacing: -0.01em; color: #006A45;">
        Naturally<br/><span style="color: #00AD5A; font-weight: 600;">San Diego</span>
      </span>
    </a>

    <!-- Desktop nav links with animated dropdowns -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navItems.map(item => (
        <div class="nav-group relative">
          <a
            href={item.href}
            class="text-sm font-semibold text-gray-600 hover:text-gray-900 transition-colors flex items-center gap-1.5 px-3 py-5 rounded-lg hover:bg-gray-50"
            style="font-family: 'Poppins', sans-serif;"
          >
            {item.label}
            <svg class="w-3 h-3 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <!-- Animated dropdown with section color accent -->
          <div class="nav-dropdown absolute top-full left-0 pt-2" style="z-index: 100;">
            <div class="bg-white rounded-2xl py-2 min-w-[200px] border border-gray-100" style="box-shadow: 0 12px 40px rgba(0,0,0,0.10);">
              <!-- Section color bar at top -->
              <div class="mx-3 mb-2 h-0.5 rounded-full" style={`background-color: ${item.color};`}></div>
              {item.children.map(child => (
                <a
                  href={child.href}
                  class="block px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors rounded-lg mx-1"
                  style="font-family: 'Poppins', sans-serif;"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </nav>

    <!-- Desktop CTA buttons -->
    <div class="hidden md:flex items-center gap-2">
      <a
        href="/community/membership"
        class="text-sm font-bold px-4 py-2 rounded-full border border-gray-200 text-gray-700 hover:border-[#00AD5A] hover:text-[#00AD5A] transition-colors"
        style="font-family: 'Poppins', sans-serif;"
      >
        Be a Member
      </a>
      <a
        href="/community/sponsorship"
        class="text-sm font-bold px-4 py-2 rounded-full border border-gray-200 text-gray-700 hover:border-[#00B2AD] hover:text-[#00B2AD] transition-colors"
        style="font-family: 'Poppins', sans-serif;"
      >
        Be a Sponsor
      </a>
      <a
        href="/programs/event-calendar"
        class="text-sm font-bold px-4 py-2 rounded-full border border-gray-200 text-gray-700 hover:border-[#006A45] hover:text-[#006A45] transition-colors"
        style="font-family: 'Poppins', sans-serif;"
      >
        Events
      </a>
      <a
        href="/member-portal"
        class="text-sm font-bold px-5 py-2 rounded-full bg-[#F26447] text-white hover:bg-orange-500 transition-colors"
        style="font-family: 'Poppins', sans-serif;"
      >
        Member Portal
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-700 rounded-lg hover:bg-gray-100 transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-overlay"
    >
      <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

  </div>
</header>

<!-- ─── Mobile full-screen overlay ────────────────────────────── -->
<div
  id="mobile-overlay"
  class="fixed inset-0 bg-white flex flex-col md:hidden"
  style="z-index: 49; display: none !important; opacity: 0; transform: translateY(-6px); transition: opacity 0.22s ease, transform 0.22s ease;"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>

  <!-- Overlay header (mirrors the sticky nav height) -->
  <div class="flex items-center justify-between px-6 h-16 border-b border-gray-100 flex-shrink-0">
    <a href="/" class="flex items-center gap-2.5" tabindex="-1" aria-hidden="true">
      <img src="/NN_Icon.png" alt="" class="h-9 w-9 rounded-full" />
      <span style="font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 0.9rem; line-height: 1.1; letter-spacing: -0.01em; color: #006A45;">
        Naturally<br/><span style="color: #00AD5A; font-weight: 600;">San Diego</span>
      </span>
    </a>
    <button
      id="mobile-overlay-close"
      class="p-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors"
      aria-label="Close menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Scrollable body -->
  <div class="flex-1 overflow-y-auto overscroll-contain">

    <!-- ── Quick-access strip ── -->
    <div class="px-5 pt-5 pb-4 grid grid-cols-2 gap-3">
      <a
        href="/programs/event-calendar"
        class="flex items-center justify-center gap-2 bg-[#006A45] text-white font-bold text-sm px-4 py-3.5 rounded-2xl"
        style="font-family: 'Poppins', sans-serif;"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Events
      </a>
      <a
        href="/member-portal"
        class="flex items-center justify-center gap-2 bg-[#F26447] text-white font-bold text-sm px-4 py-3.5 rounded-2xl"
        style="font-family: 'Poppins', sans-serif;"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        Member Portal
      </a>
    </div>

    <!-- ── Accordion nav ── -->
    <nav class="px-5 pb-2" aria-label="Mobile navigation">
      {navItems.map((item, i) => (
        <div class={`border-t ${i === navItems.length - 1 ? 'border-b' : ''} border-gray-100`}>
          <button
            class="mobile-acc-btn w-full flex items-center justify-between py-4 text-left"
            aria-expanded="false"
          >
            <div class="flex items-center gap-3">
              <div class="w-1 h-5 rounded-full flex-shrink-0" style={`background-color: ${item.color};`}></div>
              <span
                class="font-bold text-[#111] text-base"
                style="font-family: 'Poppins', sans-serif;"
              >
                {item.label}
              </span>
            </div>
            <svg
              class="mobile-chevron w-4 h-4 text-gray-400 flex-shrink-0 transition-transform duration-200"
              fill="none" stroke="currentColor" viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            class="mobile-acc-panel overflow-hidden"
            style="max-height: 0; transition: max-height 0.25s ease;"
          >
            <div class="pb-3 pl-4 flex flex-col">
              {item.children.map(child => (
                <a
                  href={child.href}
                  class="py-2.5 text-sm font-medium text-gray-500 hover:text-[#111] transition-colors border-l-2 border-gray-100 pl-4 hover:border-gray-300"
                  style="font-family: 'Poppins', sans-serif;"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </nav>

    <!-- ── Bottom CTA strip ── -->
    <div class="px-5 pt-5 pb-8 flex flex-col gap-3">
      <a
        href="/community/membership"
        class="text-center font-bold text-sm py-3.5 rounded-full bg-[#00AD5A] text-white"
        style="font-family: 'Poppins', sans-serif;"
      >
        Become a Member
      </a>
      <a
        href="/community/sponsorship"
        class="text-center font-bold text-sm py-3.5 rounded-full border border-gray-200 text-gray-700"
        style="font-family: 'Poppins', sans-serif;"
      >
        Become a Sponsor
      </a>
    </div>

  </div>
</div>

<script>
  // ── Desktop dropdown hover ─────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.nav-group').forEach(group => {
    const dropdown = group.querySelector<HTMLElement>('.nav-dropdown');
    if (!dropdown) return;
    let timer: ReturnType<typeof setTimeout>;
    group.addEventListener('mouseenter', () => {
      clearTimeout(timer);
      dropdown.style.display = 'block';
      requestAnimationFrame(() => { dropdown.style.opacity = '1'; dropdown.style.transform = 'translateY(0)'; });
    });
    group.addEventListener('mouseleave', () => {
      timer = setTimeout(() => { dropdown.style.opacity = '0'; dropdown.style.transform = 'translateY(-4px)'; setTimeout(() => { dropdown.style.display = 'none'; }, 150); }, 80);
    });
    dropdown.style.cssText += '; display:none; opacity:0; transform:translateY(-4px); transition: opacity 0.15s ease, transform 0.15s ease;';
  });

  // ── Mobile overlay open/close ──────────────────────────────────
  const btn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-overlay') as HTMLElement;
  const closeBtn = document.getElementById('mobile-overlay-close');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const openMenu = () => {
    overlay.style.removeProperty('display');
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    btn?.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        overlay.style.opacity = '1';
        overlay.style.transform = 'translateY(0)';
      });
    });
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
  };

  const closeMenu = () => {
    overlay.style.opacity = '0';
    overlay.style.transform = 'translateY(-6px)';
    document.body.style.overflow = '';
    btn?.setAttribute('aria-expanded', 'false');
    setTimeout(() => { overlay.style.display = 'none'; }, 220);
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  };

  btn?.addEventListener('click', () => {
    const isOpen = overlay.style.display === 'flex';
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  // Close on nav link click
  overlay.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeMenu);
  });

  // ── Accordion ─────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.mobile-acc-btn').forEach(btn => {
    const panel = btn.nextElementSibling as HTMLElement;
    const chevron = btn.querySelector<HTMLElement>('.mobile-chevron');

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll<HTMLElement>('.mobile-acc-btn').forEach(other => {
        if (other === btn) return;
        other.setAttribute('aria-expanded', 'false');
        const otherPanel = other.nextElementSibling as HTMLElement;
        const otherChevron = other.querySelector<HTMLElement>('.mobile-chevron');
        otherPanel.style.maxHeight = '0';
        if (otherChevron) otherChevron.style.transform = '';
      });

      // Toggle this one
      btn.setAttribute('aria-expanded', String(!isOpen));
      panel.style.maxHeight = isOpen ? '0' : panel.scrollHeight + 'px';
      if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    });
  });
</script>
