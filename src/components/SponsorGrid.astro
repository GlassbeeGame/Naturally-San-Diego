---

<div class="space-y-12">
  {tiers.map(tier => (
    <div>
      <h3
        class="text-xs font-bold uppercase tracking-widest text-[#00AD5A] mb-6 pb-3 border-b border-gray-100"
        style="font-family: 'Poppins', sans-serif;"
      >
        {tier.label}
      </h3>
      <div class="flex flex-wrap items-center gap-6">
        {tier.sponsors.map(s => (
          s.file ? (
            <img
              src={`/sponsors/${s.file}`}
              alt={s.name}
              class={`${tier.size} w-auto max-w-[120px] object-contain grayscale hover:grayscale-0 transition-all opacity-70 hover:opacity-100`}
              loading="lazy"
            />
          ) : (
            <span
              class="inline-block border border-gray-200 rounded-xl px-4 py-2 text-sm font-semibold text-gray-500"
              style="font-family: 'Poppins', sans-serif;"
            >
              {s.name}
            </span>
          )
        ))}
      </div>
    </div>
  ))}
</div>
