---
interface Props {
  color: 'orange' | 'green' | 'lime' | 'teal';
  type: string;
  title: string;
  date: string;
  description: string;
  href: string;
}

const { color, type, title, date, description, href } = Astro.props;

const bandColors = {
  orange: '#F26447',
  green: '#006A45',
  lime: '#C3DB66',
  teal: '#00B2AD',
};

const bandTextColors = {
  orange: 'text-white',
  green: 'text-white',
  lime: 'text-[#006A45]',
  teal: 'text-white',
};

const bandColor = bandColors[color];
const textColor = bandTextColors[color];
---

<a
  href={href}
  class="snap-start flex-shrink-0 w-[280px] rounded-2xl overflow-hidden bg-white hover-lift"
  style="min-height: 340px; display: flex; flex-direction: column; border: 1px solid rgba(0,0,0,0.07);"
>
  <!-- Colored top band — taller, with date overlaid -->
  <div
    class="relative flex flex-col justify-between px-6 pt-6 pb-5"
    style={`background-color: ${bandColor}; min-height: 120px;`}
  >
    <span
      class={`text-xs font-bold uppercase tracking-widest ${textColor} opacity-80`}
      style="font-family: 'Poppins', sans-serif; letter-spacing: 0.15em;"
    >
      {type}
    </span>
    <div>
      <p
        class={`text-4xl font-black leading-none ${textColor}`}
        style="font-family: 'Poppins', sans-serif; opacity: 0.18;"
      >
        {date}
      </p>
    </div>
  </div>

  <!-- Card body -->
  <div class="px-6 py-6 flex flex-col flex-1">
    <p
      class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3"
      style="font-family: 'Poppins', sans-serif;"
    >
      {date}
    </p>
    <h3
      class="text-xl font-black text-[#111] leading-tight mb-3"
      style="font-family: 'Poppins', sans-serif; letter-spacing: -0.02em;"
    >
      {title}
    </h3>
    <p class="text-sm text-[#111]/55 leading-relaxed flex-1" style="font-family: 'Lato', sans-serif;">
      {description}
    </p>
    <div class="mt-5 pt-4 border-t border-gray-100">
      <span
        class="arrow-link text-xs font-bold text-[#00AD5A]"
        style="font-family: 'Poppins', sans-serif;"
      >
        Learn more <span>→</span>
      </span>
    </div>
  </div>
</a>
